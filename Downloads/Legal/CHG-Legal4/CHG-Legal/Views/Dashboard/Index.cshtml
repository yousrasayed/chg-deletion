        x: {
        ticks: { stepSize: 1, color: '#5a7a78' },
        title: { display: true, text: 'عدد الفروع', color: '#4a9f9c' },
        grid: { color: '#e0eceb' }
        },
        y: {
        ticks: { color: '#5a7a78' },
        grid: { display: false }
        }
        }
        }
        });
        }
        
        // Expandable rows functionality for yearly reports
        $(document).ready(function() {
        $('.expandable-row').off('click').on('click', function(e) {
        var $this = $(this);
        var year = $this.data('year');
        var $nextRow = $this.next('.detail-row');
                
        if ($nextRow.length && $nextRow.hasClass('detail-row')) {
        $nextRow.remove();
        $this.removeClass('expanded');
        } else {
        var reports = @Html.Raw(Json.Serialize(Model.YearlyReports));
        var report = reports.find(r => r.year === year);
                    
        if (report) {
        var detailHtml = `
        <tr class="detail-row">
        <td colspan="8">
        <div class="detail-content">
        <div class="detail-title mb-3">
        <i class="fas fa-chart-line me-2"></i>
        تفاصيل سنة ${year}
        </div>
        <div class="row">
        <div class="col-md-6">
        <div class="mb-3">
        <strong style="color: #4a9f9c;">توزيع الشركات حسب عدد المساهمين:</strong>
        <ul class="mt-2">
        ${Object.entries(report.companiesBySize).map(([type, count]) =>
        `<li>${type}: ${count} شركة</li>`
        ).join('')}
        </ul>
        </div>
        </div>
        <div class="col-md-6">
        <div class="mb-3">
        <strong style="color: #4a9f9c;">مؤشرات إضافية:</strong>
        <ul class="mt-2">
        <li>متوسط المساهمين لكل شركة: ${(report.totalShareholders / report.totalCompanies).toFixed(1)}</li>
        <li>متوسط الفروع لكل شركة: ${(report.totalBranches / report.totalCompanies).toFixed(1)}</li>
        </ul>
        </div>
        </div>
        </div>
        </div>
        </td>
        </tr>
        `;
        $this.after(detailHtml);
        }
        $this.addClass('expanded');
        }
        });
            
        $('.expand-icon').off('click').on('click', function(e) {
        e.stopPropagation();
        $(this).closest('.expandable-row').trigger('click');
        });
        });
    </script>
}