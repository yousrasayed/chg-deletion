@{
    ViewData["Title"] = "إدارة المستخدمين";
    var roles = ViewBag.Roles as List<CHG_Legal.Models.Entities.Role>;
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    var token = Xsrf.GetAndStoreTokens(Context).RequestToken;
}

<script>
    window.antiForgeryToken = '@token';
</script>

<div class="d-flex">
    @await Html.PartialAsync("_SidebarPartial")
    <div class="flex-grow-1 p-4" style="background-color: #f0f7f7;">
        @* <div class="header mb-4" style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); border-radius: 15px; padding: 20px 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h2 class="mb-0 text-white">إدارة المستخدمين</h2>
        </div> *@

        <button class="btn mb-4" id="addUserBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px; padding: 8px 20px;">
            <i class="fas fa-plus"></i> إضافة مستخدم
        </button>

        <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
            <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                <i class="fas fa-users me-2"></i> قائمة المستخدمين
            </div>
            <div class="card-body p-0 table-container">
                <div class="table-responsive">
                    <table class="table mb-0" id="usersTable" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); color: white;">
                                <th style="padding: 15px; text-align: center; width: 5%; background: transparent !important;">#</th>
                                <th style="padding: 15px; text-align: center; width: 30%; background: transparent !important;">اسم المستخدم</th>
                                <th style="padding: 15px; text-align: center; width: 20%; background: transparent !important;">الدور</th>
                                <th style="padding: 15px; text-align: center; width: 15%; background: transparent !important;">الحالة</th>
                                <th style="padding: 15px; text-align: center; width: 30%; background: transparent !important;">الإجراءات</th>
                             </tr>
                        </thead>
                        <tbody id="tableBody">
                            @{
                                var index = 1;
                                foreach (var user in Model)
                                {
                                    <tr data-id="@user.User_ID" style="border-bottom: 1px solid #e0eceb; transition: all 0.2s ease;">
                                        <td style="padding: 12px; text-align: center; color: #2c5a58;">@index</td>
                                        <td style="padding: 12px; text-align: center; color: #2c5a58;">@user.User_Name</td>
                                        <td style="padding: 12px; text-align: center; color: #2c5a58;">@user.RoleName</td>
                                        <td style="padding: 12px; text-align: center;">
                                            @if (user.Active)
                                            {
                                                <span class="badge" style="background: #28a745; padding: 5px 12px; border-radius: 20px;">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background: #dc3545; padding: 5px 12px; border-radius: 20px;">غير نشط</span>
                                            }
                                        </td>
                                        <td style="padding: 12px; text-align: center;">
                                            <button class="btn btn-sm" onclick="editUser(@user.User_ID)" title="تعديل" style="background: #ffc107; border: none; color: #2c3e50; border-radius: 8px; margin: 0 3px; padding: 5px 10px;">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-sm" onclick="deleteUser(@user.User_ID)" title="حذف" style="background: #dc3545; border: none; color: white; border-radius: 8px; margin: 0 3px; padding: 5px 10px;">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden;">
            <div class="modal-header" style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); color: white; border-bottom: none;">
                <h5 class="modal-title" id="modalTitle">إضافة مستخدم</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="background-color: #f0f7f7;">
                <form id="userForm">
                    <input type="hidden" id="userId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #4a9f9c;">اسم المستخدم</label>
                        <input type="text" class="form-control" id="userName" required style="border-radius: 10px; border: 1px solid #e0eceb;">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #4a9f9c;">الدور</label>
                        <select class="form-select" id="roleId" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            @foreach (var role in roles)
                            {
                                <option value="@role.RoleID">@role.RoleName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isActive" checked style="border-color: #7bc6c3;">
                            <label class="form-check-label fw-bold" style="color: #4a9f9c;">نشط</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #4a9f9c;">كلمة السر</label>
                        <div class="password-wrapper position-relative">
                            <input type="password" class="form-control" id="password" style="border-radius: 10px; border: 1px solid #e0eceb; padding-left: 40px;">
                            <button type="button" class="password-toggle position-absolute" onclick="togglePasswordVisibility(this, 'password')" style="left: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #7bc6c3;">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <small class="text-muted d-block mt-1">
                            <i class="fas fa-info-circle" style="color: #7bc6c3;"></i>
                            <span class="fw-bold" style="color: #4a9f9c;">قواعد كلمة السر:</span>
                            <ul class="mt-1 mb-0 ps-3 small" style="color: #5a7a78;">
                                <li>8 أحرف على الأقل</li>
                                <li>حرف كبير (A-Z) على الأقل</li>
                                <li>حرف صغير (a-z) على الأقل</li>
                                <li>رقم (0-9) على الأقل</li>
                                <li>رمز خاص (!@@#$%^&*) على الأقل</li>
                            </ul>
                        </small>
                        <small class="text-muted mt-2 d-block" style="color: #7bc6c3;">اتركها فارغة للحفاظ على كلمة السر الحالية عند التعديل</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #4a9f9c;">تأكيد كلمة السر</label>
                        <div class="password-wrapper position-relative">
                            <input type="password" class="form-control" id="confirmPassword" style="border-radius: 10px; border: 1px solid #e0eceb; padding-left: 40px;">
                            <button type="button" class="password-toggle position-absolute" onclick="togglePasswordVisibility(this, 'confirmPassword')" style="left: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #7bc6c3;">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="background: #f8fbfb; border-top: 1px solid #e0eceb;">
                <button type="button" class="btn" data-bs-dismiss="modal" style="background: #6c757d; border: none; color: white; border-radius: 10px;">إلغاء</button>
                <button type="button" class="btn" id="saveUserBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">حفظ</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom styling for users page */
    
    /* Force header background to show */
    #usersTable thead tr {
        background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%) !important;
    }
    
    #usersTable thead th {
        background: transparent !important;
        color: white !important;
        font-weight: 600;
        border: none !important;
    }
    
    /* Table hover effect */
    #usersTable tbody tr {
        transition: all 0.2s ease;
    }
    
    #usersTable tbody tr:hover {
        background-color: #f8fbfb !important;
        transform: scale(1.01);
        box-shadow: 0 4px 12px rgba(101, 184, 181, 0.15);
    }
    
    /* Remove any default table background */
    .table {
        background-color: transparent !important;
    }
    
    /* Custom scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    ::-webkit-scrollbar-track {
        background: #e0eceb;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb {
        background: #7bc6c3;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: #65b8b5;
    }
    
    /* Form inputs focus effect */
    .form-control:focus, .form-select:focus {
        border-color: #7bc6c3;
        box-shadow: 0 0 0 0.2rem rgba(123, 198, 195, 0.25);
    }
    
    /* Form switch styling */
    .form-check-input:checked {
        background-color: #7bc6c3;
        border-color: #7bc6c3;
    }
    
    /* Password toggle button hover */
    .password-toggle:hover {
        color: #4a9f9c !important;
    }
    
    /* Table container padding fix */
    .table-container {
        overflow-x: auto;
    }
    
    /* Make table responsive */
    .table-responsive {
        border-radius: 0 0 20px 20px;
    }
    
    /* Remove any conflicting styles */
    .table thead th {
        border-bottom: none !important;
    }
</style>

@section Scripts {
    <script>
        // Password validation function with new rules
        function validatePasswordStrength(password) {
            var errors = [];
            
            if (!password || password.length === 0) {
                return []; // Empty password is allowed only for update
            }
            
            if (password.length < 8) {
                errors.push('• كلمة السر يجب أن تكون 8 أحرف على الأقل');
            }
            if (!/[a-z]/.test(password)) {
                errors.push('• حرف صغير (a-z) على الأقل');
            }
            if (!/[A-Z]/.test(password)) {
                errors.push('• حرف كبير (A-Z) على الأقل');
            }
            if (!/\d/.test(password)) {
                errors.push('• رقم (0-9) على الأقل');
            }
            if (!/[\W_]/.test(password)) {
                errors.push('• رمز خاص (!@@#$%^&*) على الأقل');
            }
            
            return errors;
        }

        let editingUserId = null;

        $('#addUserBtn').click(function() {
            editingUserId = null;
            $('#modalTitle').text('إضافة مستخدم');
            $('#userForm')[0].reset();
            $('#userId').val('');
            $('#password').val('').prop('required', true);
            $('#confirmPassword').val('').prop('required', true);
            $('#isActive').prop('checked', true);
            $('#roleId').val('2');
            $('#userModal').modal('show');
        });

        window.editUser = function(id) {
            $.get('/Admin/GetUser?id=' + id, function(user) {
                editingUserId = id;
                $('#modalTitle').text('تعديل مستخدم');
                $('#userId').val(user.user_ID);
                $('#userName').val(user.user_Name);
                $('#roleId').val(user.roleID);
                $('#isActive').prop('checked', user.active);
                $('#password').val('').prop('required', false);
                $('#confirmPassword').val('').prop('required', false);
                $('#userModal').modal('show');
            });
        };

        window.deleteUser = function(id) {
            if (!confirm('هل أنت متأكد من حذف هذا المستخدم؟')) return;
            
            $.ajax({
                url: '/Admin/DeleteUser',
                type: 'POST',
                data: { id: id },
                headers: { 'RequestVerificationToken': window.antiForgeryToken },
                success: function() {
                    location.reload();
                },
                error: function(xhr) {
                    if (typeof showToast === 'function') {
                        showToast(xhr.responseJSON?.message || 'فشل في الحذف', 'danger');
                    } else {
                        alert(xhr.responseJSON?.message || 'فشل في الحذف');
                    }
                }
            });
        };

        $('#saveUserBtn').click(function() {
            var password = $('#password').val();
            var confirmPassword = $('#confirmPassword').val();
            
            // Validate password strength (only for new user or when password is provided)
            if (!editingUserId || (editingUserId && password)) {
                var passwordErrors = validatePasswordStrength(password);
                if (passwordErrors.length > 0) {
                    if (typeof showToast === 'function') {
                        showToast('كلمة السر غير متوافقة مع القواعد:\n' + passwordErrors.join('\n'), 'danger');
                    } else {
                        alert('كلمة السر غير متوافقة مع القواعد:\n' + passwordErrors.join('\n'));
                    }
                    return;
                }
            }
            
            if (password !== confirmPassword) {
                if (typeof showToast === 'function') {
                    showToast('كلمة السر غير متطابقة', 'danger');
                } else {
                    alert('كلمة السر غير متطابقة');
                }
                return;
            }
            
            // For new user, password is required
            if (!editingUserId && (!password || password.length === 0)) {
                if (typeof showToast === 'function') {
                    showToast('كلمة السر مطلوبة للمستخدم الجديد', 'danger');
                } else {
                    alert('كلمة السر مطلوبة للمستخدم الجديد');
                }
                return;
            }
            
            var userData = {
                user_ID: $('#userId').val() || null,
                user_Name: $('#userName').val(),
                password: password,
                roleID: $('#roleId').val(),
                active: $('#isActive').is(':checked')
            };
            
            var url = editingUserId ? '/Admin/UpdateUser' : '/Admin/AddUser';
            
            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                headers: {
                    'RequestVerificationToken': window.antiForgeryToken
                },
                success: function() {
                    $('#userModal').modal('hide');
                    location.reload();
                },
                error: function(xhr) {
                    var errorMsg = 'حدث خطأ';
                    if (xhr.status === 400) {
                        if (xhr.responseJSON && xhr.responseJSON.errors) {
                            errorMsg = xhr.responseJSON.errors.join('\n');
                        } else if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        }
                    }
                    if (typeof showToast === 'function') {
                        showToast(errorMsg, 'danger');
                    } else {
                        alert(errorMsg);
                    }
                }
            });
        });
    </script>
    
    <!-- Toggle password function -->
    <script>
        function togglePasswordVisibility(button, inputId) {
            var input = document.getElementById(inputId);
            if (input) {
                if (input.type === 'password') {
                    input.type = 'text';
                    button.innerHTML = '<i class="fas fa-eye-slash"></i>';
                } else {
                    input.type = 'password';
                    button.innerHTML = '<i class="fas fa-eye"></i>';
                }
            }
        }
    </script>
    
    <!-- Change Password Script for Admin -->
    <script>
        // Password validation for change password
        function validateNewPassword(password) {
            var errors = [];
            
            if (!password || password.length === 0) {
                errors.push('كلمة السر الجديدة مطلوبة');
                return errors;
            }
            
            if (password.length < 8) {
                errors.push('• كلمة السر يجب أن تكون 8 أحرف على الأقل');
            }
            if (!/[a-z]/.test(password)) {
                errors.push('• حرف صغير (a-z) على الأقل');
            }
            if (!/[A-Z]/.test(password)) {
                errors.push('• حرف كبير (A-Z) على الأقل');
            }
            if (!/\d/.test(password)) {
                errors.push('• رقم (0-9) على الأقل');
            }
            if (!/[\W_]/.test(password)) {
                errors.push('• رمز خاص (!@@#$%^&*) على الأقل');
            }
            
            return errors;
        }
        
        // Force override for change password
        (function() {
            // Wait for page to fully load
            window.addEventListener('load', function() {
            
                var saveBtn = document.getElementById('savePasswordBtn');
            
                if (saveBtn) {
                    // Remove all existing event listeners
                    var oldBtn = saveBtn;
                    var newBtn = saveBtn.cloneNode(true);
                    oldBtn.parentNode.replaceChild(newBtn, oldBtn);
                
                    newBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                    
                        // Get values directly from the modal inputs
                        var currentInput = document.querySelector('#changePasswordModal #currentPassword');
                        var newInput = document.querySelector('#changePasswordModal #newPassword');
                        var confirmInput = document.querySelector('#changePasswordModal #confirmPassword');
                    
                        if (!currentInput || !newInput || !confirmInput) {
                            alert('حدث خطأ في العثور على حقول كلمة السر');
                            return;
                        }
                    
                        var currentPassword = currentInput.value;
                        var newPassword = newInput.value;
                        var confirmPassword = confirmInput.value;
                    
                        // Clear errors
                        currentInput.classList.remove('is-invalid');
                        newInput.classList.remove('is-invalid');
                        confirmInput.classList.remove('is-invalid');
                    
                        var errors = [];
                    
                        if (!currentPassword) {
                            currentInput.classList.add('is-invalid');
                            errors.push('كلمة السر الحالية مطلوبة');
                        }
                    
                        // Validate new password strength
                        var passwordErrors = validateNewPassword(newPassword);
                        if (passwordErrors.length > 0) {
                            newInput.classList.add('is-invalid');
                            errors.push('كلمة السر الجديدة غير متوافقة مع القواعد:\n' + passwordErrors.join('\n'));
                        }
                    
                        if (!confirmPassword) {
                            confirmInput.classList.add('is-invalid');
                            errors.push('تأكيد كلمة السر مطلوب');
                        } else if (newPassword !== confirmPassword) {
                            confirmInput.classList.add('is-invalid');
                            errors.push('كلمة السر غير متطابقة');
                        }
                    
                        if (errors.length > 0) {
                            if (typeof showToast === 'function') {
                                showToast(errors.join('\n'), 'danger');
                            } else {
                                alert(errors.join('\n'));
                            }
                            return;
                        }
                    
                        // Send request
                        var xhr = new XMLHttpRequest();
                        xhr.open('POST', '/Account/ChangePassword');
                        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                        xhr.setRequestHeader('RequestVerificationToken', window.antiForgeryToken);
                    
                        xhr.onload = function() {
                            if (xhr.status === 200) {
                                var response = JSON.parse(xhr.responseText);
                                var modal = bootstrap.Modal.getInstance(document.getElementById('changePasswordModal'));
                                if (modal) modal.hide();
                                document.getElementById('changePasswordForm').reset();
                                if (typeof showToast === 'function') {
                                    showToast(response.message || 'تم تغيير كلمة السر بنجاح', 'success');
                                } else {
                                    alert(response.message || 'تم تغيير كلمة السر بنجاح');
                                }
                            } else {
                                try {
                                    var response = JSON.parse(xhr.responseText);
                                    if (typeof showToast === 'function') {
                                        showToast(response.message || 'حدث خطأ', 'danger');
                                    } else {
                                        alert(response.message || 'حدث خطأ');
                                    }
                                } catch(e) {
                                    if (typeof showToast === 'function') {
                                        showToast('حدث خطأ في تغيير كلمة السر', 'danger');
                                    } else {
                                        alert('حدث خطأ في تغيير كلمة السر');
                                    }
                                }
                            }
                        };
                    
                        xhr.onerror = function() {
                            if (typeof showToast === 'function') {
                                showToast('حدث خطأ في الاتصال', 'danger');
                            } else {
                                alert('حدث خطأ في الاتصال');
                            }
                        };
                    
                        xhr.send('currentPassword=' + encodeURIComponent(currentPassword) +
                                '&newPassword=' + encodeURIComponent(newPassword));
                    });
                }
            });
        })();
    </script>
}