@* @model List<CHG_Legal.Models.Entities.Board>
@{
    ViewData["Title"] = "التقارير";
}

<div class="d-flex">
    @await Html.PartialAsync("_SidebarPartial")
    <div class="flex-grow-1 p-4" style="background-color: #f0f7f7;">
        <div class="header mb-4" style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); border-radius: 15px; padding: 20px 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h2 class="mb-0 text-white">التقارير</h2>
        </div>

        <!-- First Row: Meetings by Type & Meetings by Hospital -->
        <div class="row g-4">
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-chart-bar me-2"></i> الاجتماعات حسب النوع
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center p-4" style="height: 400px;">
                        <canvas id="meetingsByTypeReport" style="width: 100%; height: 100%;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-chart-pie me-2"></i> الاجتماعات حسب المستشفى
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center p-4" style="height: 400px;">
                        <canvas id="meetingsByHospitalReport" style="width: 100%; height: 100%;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Third Row: Monthly Trend -->
        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-chart-line me-2"></i> الاتجاه الشهري للاجتماعات
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center p-4" style="height: 450px;">
                        <canvas id="monthlyTrendChart" style="width: 100%; height: 100%;"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* Custom styling for charts */
        .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(101, 184, 181, 0.15) !important;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
        }
        
        ::-webkit-scrollbar-track {
        background: #e0eceb;
        border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
        background: #7bc6c3;
        border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
        background: #65b8b5;
        }
    </style>
    
    <script>
        const meetings = @Html.Raw(Json.Serialize(Model));
        
        // New color palette
        const primaryColor = '#7bc6c3';
        const primaryDark = '#65b8b5';
        const primaryLight = '#91d3d1';
        const primaryLightColor = 'rgba(123, 198, 195, 0.1)';
        const gradientColors = ['#91d3d1', '#7bc6c3', '#65b8b5'];
        
        // ========== 1. Meetings by type (Bar Chart) ==========
        let typeCount = {};
        meetings.forEach(m => {
        if (m.meetingType) {
        typeCount[m.meetingType] = (typeCount[m.meetingType] || 0) + 1;
        }
        });
        
        const ctx1 = document.getElementById('meetingsByTypeReport').getContext('2d');
        new Chart(ctx1, {
        type: 'bar',
        data: {
        labels: Object.keys(typeCount),
        datasets: [{
        label: 'عدد الاجتماعات',
        data: Object.values(typeCount),
        backgroundColor: (context) => {
        const chart = context.chart;
        const {ctx, chartArea} = chart;
        if (!chartArea) return primaryColor;
        const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
        gradient.addColorStop(0, primaryDark);
        gradient.addColorStop(0.5, primaryColor);
        gradient.addColorStop(1, primaryLight);
        return gradient;
        },
        borderColor: primaryDark,
        borderWidth: 1,
        borderRadius: 8,
        barPercentage: 0.7,
        categoryPercentage: 0.8
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'top', labels: { font: { size: 12 }, color: '#4a9f9c' } },
        tooltip: { mode: 'index', intersect: false, backgroundColor: primaryDark, titleColor: 'white', bodyColor: 'white' }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: { stepSize: 1, font: { size: 11 }, color: '#5a7a78' },
        title: { display: true, text: 'عدد الاجتماعات', font: { size: 12 }, color: '#4a9f9c' },
        grid: { color: '#e0eceb' }
        },
        x: {
        ticks: { font: { size: 11 }, rotation: 0, color: '#5a7a78' },
        title: { display: true, text: 'نوع الاجتماع', font: { size: 12 }, color: '#4a9f9c' },
        grid: { display: false }
        }
        }
        }
        });
        
        // ========== 2. Meetings by hospital (Pie Chart) ==========
        let hospitalCount = {};
        meetings.forEach(m => {
        if (m.chgParty && m.chgParty !== '') {
        const hospitals = m.chgParty.split(',').map(h => h.trim());
        hospitals.forEach(h => {
        if (h) {
        hospitalCount[h] = (hospitalCount[h] || 0) + 1;
        }
        });
        }
        });
        
        const hospitalLabels = Object.keys(hospitalCount);
        const hospitalData = Object.values(hospitalCount);
        // Use gradient colors for pie chart
        const pieColors = hospitalLabels.map((_, index) => {
        return gradientColors[index % gradientColors.length];
        });
        
        const ctx2 = document.getElementById('meetingsByHospitalReport').getContext('2d');
        new Chart(ctx2, {
        type: 'pie',
        data: {
        labels: hospitalLabels,
        datasets: [{
        data: hospitalData,
        backgroundColor: pieColors,
        borderColor: 'white',
        borderWidth: 2
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'right', labels: { font: { size: 11 }, color: '#4a9f9c' } },
        tooltip: {
        callbacks: {
        label: function(context) {
        return `${context.label}: ${context.raw} اجتماع`;
        }
        },
        backgroundColor: primaryDark,
        titleColor: 'white',
        bodyColor: 'white'
        }
        }
        }
        });
        
        // ========== 3. Monthly trend (Line Chart) ==========
        let monthlyCount = {};
        meetings.forEach(m => {
        if (m.boardDate) {
        let date = new Date(m.boardDate);
        let month = date.getMonth() + 1;
        let year = date.getFullYear();
        let key = `${year}-${month}`;
        monthlyCount[key] = (monthlyCount[key] || 0) + 1;
        }
        });
        
        let sortedMonths = Object.keys(monthlyCount).sort();
        const monthNames = {
        1: 'يناير', 2: 'فبراير', 3: 'مارس', 4: 'أبريل', 5: 'مايو', 6: 'يونيو',
        7: 'يوليو', 8: 'أغسطس', 9: 'سبتمبر', 10: 'أكتوبر', 11: 'نوفمبر', 12: 'ديسمبر'
        };
        
        let labels = sortedMonths.map(key => {
        let [year, month] = key.split('-');
        return `${monthNames[parseInt(month)]} ${year}`;
        });
        let data = sortedMonths.map(key => monthlyCount[key]);
        
        const ctx5 = document.getElementById('monthlyTrendChart').getContext('2d');
        new Chart(ctx5, {
        type: 'line',
        data: {
        labels: labels,
        datasets: [{
        label: 'عدد الاجتماعات',
        data: data,
        borderColor: primaryColor,
        backgroundColor: (context) => {
        const chart = context.chart;
        const {ctx, chartArea} = chart;
        if (!chartArea) return primaryLightColor;
        const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
        gradient.addColorStop(0, primaryLightColor);
        gradient.addColorStop(1, 'rgba(123, 198, 195, 0.4)');
        return gradient;
        },
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: primaryColor,
        pointBorderColor: 'white',
        pointRadius: 5,
        pointHoverRadius: 7,
        pointBorderWidth: 2
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'top', labels: { font: { size: 12 }, color: '#4a9f9c' } },
        tooltip: { mode: 'index', intersect: false, backgroundColor: primaryDark, titleColor: 'white', bodyColor: 'white' }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: { stepSize: 1, font: { size: 11 }, color: '#5a7a78' },
        title: { display: true, text: 'عدد الاجتماعات', font: { size: 12 }, color: '#4a9f9c' },
        grid: { color: '#e0eceb' }
        },
        x: {
        ticks: { font: { size: 11 }, rotation: 45, color: '#5a7a78' },
        title: { display: true, text: 'الشهر والسنة', font: { size: 12 }, color: '#4a9f9c' },
        grid: { display: false }
        }
        }
        }
        });
    </script>
} *@


