        let companiesWithBranchCount = companies.map(company => ({
        name: company.name || 'بدون اسم',
        shareholderCount: getCurrentShareholdersCount(company.shareholders),
        branchCount: company.branches ? company.branches.length : 0,
        registrationDate: company.registrationDate
        })).filter(c => c.branchCount > 0)
        .sort((a, b) => b.branchCount - a.branchCount)
        .slice(0, 10);
        
        const ctx4 = document.getElementById('topCompaniesByBranchesReport').getContext('2d');
        new Chart(ctx4, {
        type: 'bar',
        data: {
        labels: companiesWithBranchCount.map(c => c.name.length > 20 ? c.name.substring(0, 20) + '...' : c.name),
        datasets: [{
        label: 'عدد الفروع',
        data: companiesWithBranchCount.map(c => c.branchCount),
        backgroundColor: (context) => {
        const chart = context.chart;
        const {ctx, chartArea} = chart;
        if (!chartArea) return primaryColor;
        const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
        gradient.addColorStop(0, primaryDark);
        gradient.addColorStop(0.5, primaryColor);
        gradient.addColorStop(1, primaryLight);
        return gradient;
        },
        borderRadius: 8
        }]
        },
        options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'top', labels: { font: { size: 12 }, color: '#4a9f9c' } },
        tooltip: {
        backgroundColor: primaryDark,
        callbacks: {
        label: function(context) {
        let company = companiesWithBranchCount[context.dataIndex];
        return [
        `الفروع: ${company.branchCount}`,
        `المساهمين: ${company.shareholderCount}`,
        `تاريخ التسجيل: ${company.registrationDate ? new Date(company.registrationDate).toLocaleDateString('ar-EG') : 'غير محدد'}`
        ];
        }
        }
        }
        },
        scales: {
        x: {
        ticks: { stepSize: 1, color: '#5a7a78' },
        title: { display: true, text: 'عدد الفروع', color: '#4a9f9c' },
        grid: { color: '#e0eceb' }
        },
        y: {
        ticks: { color: '#5a7a78' },
        grid: { display: false }
        }
        }
        }
        });
        
        // ========== 5. Monthly Registrations Trend (Line Chart) ==========
        let monthlyRegistrations = {};
        const currentYear = new Date().getFullYear();
        
        companies.forEach(company => {
        if (company.registrationDate) {
        let date = new Date(company.registrationDate);
        let month = date.getMonth() + 1;
        let year = date.getFullYear();
        let key = `${year}-${month}`;
        monthlyRegistrations[key] = (monthlyRegistrations[key] || 0) + 1;
        }
        });
        
        let sortedMonths = Object.keys(monthlyRegistrations).sort();
        const monthNames = {
        1: 'يناير', 2: 'فبراير', 3: 'مارس', 4: 'إبريل', 5: 'مايو', 6: 'يونيو',
        7: 'يوليو', 8: 'أغسطس', 9: 'سبتمبر', 10: 'أكتوبر', 11: 'نوفمبر', 12: 'ديسمبر'
        };
        
        let labels = sortedMonths.map(key => {
        let [year, month] = key.split('-');
        return `${monthNames[parseInt(month)]} ${year}`;
        });
        let data = sortedMonths.map(key => monthlyRegistrations[key]);
        
        const ctx5 = document.getElementById('monthlyRegistrationsTrendChart').getContext('2d');
        new Chart(ctx5, {
        type: 'line',
        data: {
        labels: labels,
        datasets: [{
        label: 'عدد الشركات المسجلة',
        data: data,
        borderColor: primaryColor,
        backgroundColor: (context) => {
        const chart = context.chart;
        const {ctx, chartArea} = chart;
        if (!chartArea) return primaryLightColor;
        const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
        gradient.addColorStop(0, primaryLightColor);
        gradient.addColorStop(1, 'rgba(123, 198, 195, 0.4)');
        return gradient;
        },
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: primaryColor,
        pointBorderColor: 'white',
        pointRadius: 5,
        pointHoverRadius: 7,
        pointBorderWidth: 2
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'top', labels: { font: { size: 12 }, color: '#4a9f9c' } },
        tooltip: { mode: 'index', intersect: false, backgroundColor: primaryDark, titleColor: 'white', bodyColor: 'white' }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: { stepSize: 1, font: { size: 11 }, color: '#5a7a78' },
        title: { display: true, text: 'عدد الشركات', font: { size: 12 }, color: '#4a9f9c' },
        grid: { color: '#e0eceb' }
        },
        x: {
        ticks: { font: { size: 11 }, rotation: 45, color: '#5a7a78' },
        title: { display: true, text: 'الشهر والسنة', font: { size: 12 }, color: '#4a9f9c' },
        grid: { display: false }
        }
        }
        }
        });
        
        // ========== 6. Registration Status (Doughnut Chart) ==========
        const todayDate = new Date();
        todayDate.setHours(0, 0, 0, 0);
        
        let activeCount = 0;
        let expiringCount = 0;
        let expiredCount = 0;
        let noExpiryDateCount = 0;
        
        companies.forEach(company => {
        if (!company.registrationExpiry) {
        noExpiryDateCount++;
        } else {
        let expiryDate = new Date(company.registrationExpiry);
        expiryDate.setHours(0, 0, 0, 0);
                
        if (expiryDate > todayDate) {
        activeCount++;
        // Check if expiring within 30 days
        let thirtyDaysFromNow = new Date(todayDate);
        thirtyDaysFromNow.setDate(thirtyDaysFromNow.getDate() + 30);
        if (expiryDate <= thirtyDaysFromNow) {
        expiringCount++;
        }
        } else {
        expiredCount++;
        }
        }
        });
        
        const statusLabels = [];
        const statusData = [];
        const statusColors = [];
        
        if (activeCount > 0) {
        statusLabels.push('شركات نشطة');
        statusData.push(activeCount);
        statusColors.push('#65b8b5');
        }
        if (expiringCount > 0) {
        statusLabels.push('على وشك الانتهاء');
        statusData.push(expiringCount);
        statusColors.push('#91d3d1');
        }
        if (expiredCount > 0) {
        statusLabels.push('شركات منتهية');
        statusData.push(expiredCount);
        statusColors.push('#4a9f9c');
        }
        if (noExpiryDateCount > 0) {
        statusLabels.push('بدون تاريخ انتهاء');
        statusData.push(noExpiryDateCount);
        statusColors.push('#7bc6c3');
        }
        
        const ctx6 = document.getElementById('registrationStatusChart').getContext('2d');
        new Chart(ctx6, {
        type: 'doughnut',
        data: {
        labels: statusLabels,
        datasets: [{
        data: statusData,
        backgroundColor: statusColors,
        borderColor: 'white',
        borderWidth: 2
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { position: 'bottom', labels: { font: { size: 12 }, color: '#4a9f9c' } },
        tooltip: {
        callbacks: {
        label: function(context) {
        const total = statusData.reduce((a, b) => a + b, 0);
        const percentage = ((context.raw / total) * 100).toFixed(1);
        return `${context.label}: ${context.raw} شركة (${percentage}%)`;
        }
        },
        backgroundColor: primaryDark,
        titleColor: 'white',
        bodyColor: 'white'
        }
        }
        }
        });
    </script>
}