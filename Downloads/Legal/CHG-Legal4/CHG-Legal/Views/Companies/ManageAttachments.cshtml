                    </div>
                    <div class="card-body p-4">
                        <div class="upload-section mb-4">
                            <form id="bankingUploadForm" enctype="multipart/form-data">
                                <input type="hidden" id="bankingCompanyId" value="@ViewBag.CompanyId" />
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                        <input type="file" class="form-control" id="bankingFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                        <input type="text" class="form-control" id="bankingDescription" placeholder="مثال: توكيل بنكي" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn w-100" id="uploadBankingBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                            <i class="fas fa-upload"></i> رفع
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div id="bankingAttachmentsList">
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-spinner fa-spin fa-2x mb-2 d-block" style="color: #7bc6c3;"></i>
                                <span style="color: #5a7a78;">جاري تحميل المرفقات...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 6: Non-Banking Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "nonbanking" ? "show active" : "")"
