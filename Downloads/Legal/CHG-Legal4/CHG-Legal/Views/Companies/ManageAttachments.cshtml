@{
    ViewData["Title"] = "إدارة المرفقات - " + ViewBag.CompanyName;
    Layout = "_Layout";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    var token = Xsrf.GetAndStoreTokens(Context).RequestToken;
}

<div class="d-flex">
    @await Html.PartialAsync("_SidebarPartial")
    <div class="flex-grow-1 p-4" style="background-color: #f0f7f7;">
        @* <div class="header mb-4" style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); border-radius: 15px; padding: 20px 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h2 class="mb-0 text-white">
                <i class="fas fa-paperclip me-2"></i>
                إدارة المرفقات - @ViewBag.CompanyName
            </h2>
        </div> *@

        <!-- Tabs Navigation -->
        <div class="attachments-tabs mb-4 mt-3">
            <ul class="nav nav-tabs" id="attachmentsTabs" role="tablist" style="border-bottom: 2px solid #e0eceb;">
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "company" ? "active" : "")"
                            id="company-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#company-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-building me-1"></i> بيانات الشركة
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "shareholders" ? "active" : "")"
                            id="shareholders-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#shareholders-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-users me-1"></i> المساهمين
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "branches" ? "active" : "")"
                            id="branches-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#branches-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-code-branch me-1"></i> الفروع
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "board" ? "active" : "")"
                            id="board-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#board-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-user-tie me-1"></i> أعضاء المجلس
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "banking" ? "active" : "")"
                            id="banking-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#banking-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-university me-1"></i> صلاحيات بنكية
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(ViewBag.ActiveTab == "nonbanking" ? "active" : "")"
                            id="nonbanking-attachments-tab" data-bs-toggle="tab"
                            data-bs-target="#nonbanking-attachments" type="button" role="tab"
                            style="border-radius: 10px 10px 0 0;">
                        <i class="fas fa-file-signature me-1"></i> صلاحيات غير بنكية
                    </button>
                </li>
            </ul>
        </div>

        <!-- Tabs Content -->
        <div class="tab-content">
            <!-- Tab 1: Company Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "company" ? "show active" : "")"
                 id="company-attachments" role="tabpanel">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-building me-2"></i> مرفقات بيانات الشركة
                    </div>
                    <div class="card-body p-4">
                        <div class="company-summary mb-4" style="background: linear-gradient(135deg, #f0f9fa 0%, #e8f5f6 100%); border-radius: 15px; border-right: 4px solid #7bc6c3;">
                            <div class="p-3">
                                <h6 class="mb-3" style="color: #4a9f9c; font-weight: 600;">
                                    <i class="fas fa-info-circle me-2"></i>ملخص بيانات الشركة
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-building fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">اسم الشركة</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.CompanyName</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-id-card fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">السجل التجاري</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.CommercialRegNo</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-chart-line fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">رأس المال</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.AuthorizedCapital <small>جنيه</small></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-calendar-alt fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">تاريخ التسجيل</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.RegistrationDate</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="upload-section mb-4">
                            <form id="companyUploadForm" enctype="multipart/form-data">
                                <input type="hidden" id="companyId" value="@ViewBag.CompanyId" />
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                        <input type="file" class="form-control" id="companyFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                        <input type="text" class="form-control" id="companyDescription" placeholder="مثال: عقد التأسيس" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn w-100" id="uploadCompanyBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                            <i class="fas fa-upload"></i> رفع
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div id="companyAttachmentsList">
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-spinner fa-spin fa-2x mb-2 d-block" style="color: #7bc6c3;"></i>
                                <span style="color: #5a7a78;">جاري تحميل المرفقات...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Shareholders Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "shareholders" ? "show active" : "")"
                 id="shareholders-attachments" role="tabpanel">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-users me-2"></i> مرفقات المساهمين
                    </div>
                    <div class="card-body p-0">
                        <div class="shareholders-summary p-4" style="background: linear-gradient(135deg, #f0f9fa 0%, #e8f5f6 100%);">
                            <div class="p-3">
                                <h6 class="mb-3" style="color: #4a9f9c; font-weight: 600;">
                                    <i class="fas fa-chart-pie me-2"></i>ملخص المساهمين
                                </h6>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-user-check fa-lg mb-2" style="color: #28a745;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">المساهمين النشطين</small>
                                                <span class="fw-bold" style="color: #28a745;">@ViewBag.ActiveShareholdersCount</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-user-slash fa-lg mb-2" style="color: #6c757d;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">المساهمين السابقين</small>
                                                <span class="fw-bold" style="color: #6c757d;">@ViewBag.ExitedShareholdersCount</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0" style="width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden;">
                                        <thead>
                                            <tr style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); color: white;">
                                                <th style="padding: 12px; text-align: center;">#</th>
                                                <th style="padding: 12px; text-align: center;">المساهم</th>
                                                <th style="padding: 12px; text-align: center;">الصفة</th>
                                                <th style="padding: 12px; text-align: center;">النسبة</th>
                                                <th style="padding: 12px; text-align: center;">الحالة</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                int shareholderCounter = 1;
                                            }
                                            @foreach (var shareholder in ViewBag.Shareholders)
                                            {
                                                <tr style="border-bottom: 1px solid #e0eceb;">
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@shareholderCounter</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@shareholder.Name</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@shareholder.Role</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@shareholder.SharesPercentage%</td>
                                                    <td style="padding: 10px; text-align: center;">
                                                        @if (shareholder.EndDate == null)
                                                        {
                                                            <span class="badge" style="background: #28a745; padding: 4px 10px; border-radius: 20px;">نشط</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge" style="background: #6c757d; padding: 4px 10px; border-radius: 20px;">سابق (خرج في @(shareholder.EndDate?.ToString("yyyy/MM/dd")))</span>
                                                        }
                                                    </td>
                                                </tr>
                                                shareholderCounter++;
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-4">
                            <div class="row">
                                <div class="col-md-4 mb-4">
                                    <label class="form-label fw-bold" style="color: #4a9f9c;">اختر المساهم</label>
                                    <select class="form-select" id="shareholderSelect" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                        <option value="">-- اختر مساهم --</option>
                                        @foreach (var shareholder in ViewBag.Shareholders)
                                        {
                                            <option value="@shareholder.ShareholderId">
                                                @shareholder.Name @(shareholder.EndDate != null ? "(سابق)" : "")
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div id="shareholderAttachmentsPanel" style="display: none;">
                                <div class="upload-section mb-4">
                                    <form id="shareholderUploadForm" enctype="multipart/form-data">
                                        <input type="hidden" id="selectedShareholderId" />
                                        <div class="row g-3 align-items-end">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                                <input type="file" class="form-control" id="shareholderFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                                <input type="text" class="form-control" id="shareholderDescription" placeholder="مثال: بطاقة الرقم القومي" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn w-100" id="uploadShareholderBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                                    <i class="fas fa-upload"></i> رفع
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div id="shareholderAttachmentsList">
                                    <div class="text-center text-muted py-4" style="color: #7bc6c3;">لا توجد مرفقات</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 3: Branches Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "branches" ? "show active" : "")"
                 id="branches-attachments" role="tabpanel">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-code-branch me-2"></i> مرفقات الفروع
                    </div>
                    <div class="card-body p-0">
                        <div class="branches-summary p-4" style="background: linear-gradient(135deg, #f0f9fa 0%, #e8f5f6 100%);">
                            <div class="p-3">
                                <h6 class="mb-3" style="color: #4a9f9c; font-weight: 600;">
                                    <i class="fas fa-store me-2"></i>ملخص الفروع
                                </h6>
                                
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0" style="width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden;">
                                        <thead>
                                            <tr style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); color: white;">
                                                <th style="padding: 12px; text-align: center;">#</th>
                                                <th style="padding: 12px; text-align: center;">اسم الفرع</th>
                                                <th style="padding: 12px; text-align: center;">العنوان</th>
                                                <th style="padding: 12px; text-align: center;">رقم السجل</th>
                                                <th style="padding: 12px; text-align: center;">تاريخ الانتهاء</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                int branchCounter = 1;
                                            }
                                            @foreach (var branch in ViewBag.Branches)
                                            {
                                                <tr style="border-bottom: 1px solid #e0eceb;">
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@branchCounter</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@branch.Name</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@branch.Address</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@branch.RegistrationNumber</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@(branch.ExpiryDate?.ToString("yyyy/MM/dd") ?? "-")</td>
                                                </tr>
                                                branchCounter++;
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-4">
                            <div class="row">
                                <div class="col-md-4 mb-4">
                                    <label class="form-label fw-bold" style="color: #4a9f9c;">اختر الفرع</label>
                                    <select class="form-select" id="branchSelect" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                        <option value="">-- اختر فرع --</option>
                                        @foreach (var branch in ViewBag.Branches)
                                        {
                                            <option value="@branch.BranchId">@branch.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div id="branchAttachmentsPanel" style="display: none;">
                                <div class="upload-section mb-4">
                                    <form id="branchUploadForm" enctype="multipart/form-data">
                                        <input type="hidden" id="selectedBranchId" />
                                        <div class="row g-3 align-items-end">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                                <input type="file" class="form-control" id="branchFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                                <input type="text" class="form-control" id="branchDescription" placeholder="مثال: عقد الإيجار" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn w-100" id="uploadBranchBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                                    <i class="fas fa-upload"></i> رفع
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div id="branchAttachmentsList">
                                    <div class="text-center text-muted py-4" style="color: #7bc6c3;">لا توجد مرفقات</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 4: Board Members Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "board" ? "show active" : "")"
                 id="board-attachments" role="tabpanel">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
                        <i class="fas fa-user-tie me-2"></i> مرفقات أعضاء مجلس الإدارة
                    </div>
                    <div class="card-body p-0">
                        <div class="board-summary p-4" style="background: linear-gradient(135deg, #f0f9fa 0%, #e8f5f6 100%);">
                            <div class="p-3">
                                <h6 class="mb-3" style="color: #4a9f9c; font-weight: 600;">
                                    <i class="fas fa-users me-2"></i>ملخص أعضاء مجلس الإدارة
                                </h6>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-clock fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">مدة المجلس</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.BoardDuration</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-calendar-alt fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">بداية المجلس</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.BoardStartDate</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-card text-center p-2 rounded" style="background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                            <i class="fas fa-users fa-lg mb-2" style="color: #7bc6c3;"></i>
                                            <div>
                                                <small class="text-muted d-block" style="color: #5a7a78;">عدد الأعضاء</small>
                                                <span class="fw-bold" style="color: #2c5a58;">@ViewBag.BoardMembers.Count</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0" style="width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden;">
                                        <thead>
                                            <tr style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); color: white;">
                                                <th style="padding: 12px; text-align: center;">#</th>
                                                <th style="padding: 12px; text-align: center;">العضو</th>
                                                <th style="padding: 12px; text-align: center;">المنصب</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                int memberCounter = 1;
                                            }
                                            @foreach (var member in ViewBag.BoardMembers)
                                            {
                                                <tr style="border-bottom: 1px solid #e0eceb;">
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@memberCounter</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@member.Name</td>
                                                    <td style="padding: 10px; text-align: center; color: #2c5a58;">@member.Position</td>
                                                </tr>
                                                memberCounter++;
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-4">
                            <div class="row">
                                <div class="col-md-4 mb-4">
                                    <label class="form-label fw-bold" style="color: #4a9f9c;">اختر العضو</label>
                                    <select class="form-select" id="boardMemberSelect" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                        <option value="">-- اختر عضو --</option>
                                        @foreach (var member in ViewBag.BoardMembers)
                                        {
                                            <option value="@member.MemberId">@member.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div id="boardMemberAttachmentsPanel" style="display: none;">
                                <div class="upload-section mb-4">
                                    <form id="boardMemberUploadForm" enctype="multipart/form-data">
                                        <input type="hidden" id="selectedBoardMemberId" />
                                        <div class="row g-3 align-items-end">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                                <input type="file" class="form-control" id="boardMemberFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                                <input type="text" class="form-control" id="boardMemberDescription" placeholder="مثال: الإفصاح" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn w-100" id="uploadBoardMemberBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                                    <i class="fas fa-upload"></i> رفع
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div id="boardMemberAttachmentsList">
                                    <div class="text-center text-muted py-4" style="color: #7bc6c3;">لا توجد مرفقات</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 5: Banking Attachments -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "banking" ? "show active" : "")"
                 id="banking-attachments" role="tabpanel">
                <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
