                                        <label class="form-label fw-bold" style="color: #4a9f9c;">اختر ملف</label>
                                        <input type="file" class="form-control" id="nonBankingFile" name="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold" style="color: #4a9f9c;">وصف المرفق</label>
                                        <input type="text" class="form-control" id="nonBankingDescription" placeholder="مثال: تفويض إدارة" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn w-100" id="uploadNonBankingBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px;">
                                            <i class="fas fa-upload"></i> رفع
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div id="nonBankingAttachmentsList">
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-spinner fa-spin fa-2x mb-2 d-block" style="color: #7bc6c3;"></i>
                                <span style="color: #5a7a78;">جاري تحميل المرفقات...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3 text-center">
            <a href="@Url.Action("Index")" class="btn" style="background: #6c757d; border: none; color: white; border-radius: 10px; padding: 8px 25px;">
                <i class="fas fa-arrow-right"></i> العودة إلى قائمة الشركات
            </a>
        </div>
    </div>
</div>

