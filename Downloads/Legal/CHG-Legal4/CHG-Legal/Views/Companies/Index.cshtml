@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    var token = Xsrf.GetAndStoreTokens(Context).RequestToken;
}

<!-- Search Section -->
<div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden;">
    <div class="card-body p-4" style="background: #f8fbfb;">
        <div class="search-section">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0" style="color: #4a9f9c;">
                    <i class="fas fa-search me-2"></i> بحث وتصفية الشركات
                </h6>
                <div>
                    <button class="btn btn-sm btn-teal" id="advancedSearchBtn" style="border-radius: 10px;">
                        <i class="fas fa-sliders-h me-1"></i> بحث متقدم
                    </button>
                    <button class="btn btn-sm btn-secondary" id="resetSearchBtn" style="border-radius: 10px; background: #6c757d; border: none;">
                        <i class="fas fa-undo-alt me-1"></i> إعادة تعيين
                    </button>
                </div>
            </div>
            
            <!-- Simple Search -->
            <div class="row g-3">
                <div class="col-md-7">
                    <div class="input-group" style="border-radius: 10px; overflow: hidden;">
                        <input type="text" class="form-control" id="searchInput" placeholder="ابحث باسم الشركة، رقم السجل التجاري، العنوان، أو أي كلمة..." style="border: 1px solid #e0eceb; border-left: none;">
                        <span class="input-group-text" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); color: white; border: none;">
                            <i class="fas fa-search"></i>
                        </span>
                    </div>
                    <div id="searchStats" class="mt-2 small text-muted"></div>
                </div>
                <div class="col-md-5">
                    <div class="d-flex gap-2">
                        <select class="form-select" id="filterType" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <option value="all">جميع الحقول</option>
                            <option value="name">اسم الشركة</option>
                            <option value="commercial">رقم السجل التجاري</option>
                            <option value="address">العنوان الرئيسي</option>
                            <option value="capital">رأس المال</option>
                            <option value="shareholders">عدد المساهمين</option>
                            <option value="branches">عدد الفروع</option>
                        </select>
                        <select class="form-select" id="statusFilter" style="border-radius: 10px; border: 1px solid #e0eceb; width: 140px;">
                            <option value="all">جميع الحالات</option>
                            <option value="active">نشطة</option>
                            <option value="expiring">على وشك الانتهاء</option>
                            <option value="expired">منتهية</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <!-- Advanced Search (Hidden by default) -->
            <div id="advancedSearchPanel" style="display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid #e0eceb;">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">اسم الشركة</label>
                        <input type="text" class="form-control adv-search" id="advName" placeholder="اسم الشركة" style="border-radius: 10px; border: 1px solid #e0eceb;">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">رقم السجل التجاري</label>
                        <input type="text" class="form-control adv-search" id="advCommercial" placeholder="رقم السجل" style="border-radius: 10px; border: 1px solid #e0eceb;">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">العنوان</label>
                        <input type="text" class="form-control adv-search" id="advAddress" placeholder="العنوان الرئيسي" style="border-radius: 10px; border: 1px solid #e0eceb;">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">رأس المال (من - إلى)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control adv-search" id="advCapitalMin" placeholder="الحد الأدنى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <input type="number" class="form-control adv-search" id="advCapitalMax" placeholder="الحد الأقصى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">عدد المساهمين (من - إلى)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control adv-search" id="advShareholdersMin" placeholder="الحد الأدنى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <input type="number" class="form-control adv-search" id="advShareholdersMax" placeholder="الحد الأقصى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">عدد الفروع (من - إلى)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control adv-search" id="advBranchesMin" placeholder="الحد الأدنى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <input type="number" class="form-control adv-search" id="advBranchesMax" placeholder="الحد الأقصى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">تاريخ التسجيل</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control adv-search" id="advDateFrom" placeholder="من" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <input type="date" class="form-control adv-search" id="advDateTo" placeholder="إلى" style="border-radius: 10px; border: 1px solid #e0eceb;">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold" style="color: #4a9f9c;">حالة التسجيل</label>
                        <select class="form-select adv-search" id="advStatus" style="border-radius: 10px; border: 1px solid #e0eceb;">
                            <option value="all">الكل</option>
                            <option value="active">نشطة</option>
                            <option value="expiring">على وشك الانتهاء (30 يوم)</option>
                            <option value="expired">منتهية</option>
                        </select>
                    </div>
                    <div class="col-md-12 text-center mt-3">
                        <button class="btn btn-teal" id="applyAdvancedSearch" style="border-radius: 10px;">
                            <i class="fas fa-search me-2"></i> تطبيق البحث المتقدم
                        </button>
                        <button class="btn btn-secondary" id="clearAdvancedSearch" style="border-radius: 10px; background: #6c757d; border: none;">
                            <i class="fas fa-times me-2"></i> مسح الكل
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden;">
    <div class="card-header bg-white border-0 pt-4 pb-0 px-4" style="color: #4a9f9c; font-weight: bold;">
        <i class="fas fa-building me-2"></i> قائمة الشركات
        <button class="btn btn-sm float-start" id="addNewCompanyBtn" style="background: linear-gradient(135deg, #91d3d1, #7bc6c3, #65b8b5); border: none; color: white; border-radius: 10px; padding: 6px 15px;">
            <i class="fas fa-plus"></i> إضافة شركة جديدة
        </button>
    </div>
    <div class="card-body p-0 table-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="companiesTable" style="width: 100%; border-collapse: separate; border-spacing: 0 8px;">
                <thead>
                    <tr>
                        <th style="padding: 12px 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px;">#</th>
                        <th style="padding: 12px 15px;">اسم الشركة</th>
                        <th style="padding: 12px 15px;">رقم السجل التجاري</th>
                        <th style="padding: 12px 15px;">الحالة</th>
                        <th style="padding: 12px 15px;">رأس المال (جنيه)</th>
                        <th style="padding: 12px 15px;">عدد المساهمين</th>
                        <th style="padding: 12px 15px;">عدد الفروع</th>
                        <th style="padding: 12px 15px; border-top-left-radius: 15px; border-bottom-left-radius: 15px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="companiesTableBody">
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="fas fa-building fa-2x mb-2 d-block" style="color: #7bc6c3;"></i>
                            لا توجد شركات حالياً، اضغط على "إضافة شركة جديدة" للبدء
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<!-- Company Modal -->
<div class="modal fade" id="companyModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden;">
            <div class="modal-header" style="background: linear-gradient(135deg, #91d3d1 0%, #7bc6c3 50%, #65b8b5 100%); color: white; border-bottom: none;">
                <h5 class="modal-title" id="companyModalTitle">
                    <i class="fas fa-building me-2"></i> إضافة شركة جديدة
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="background-color: #f0f7f7;">
                <!-- Tabs Navigation -->
                <div class="companies-tabs mb-4">
                    <ul class="nav nav-tabs" id="companyTabs" role="tablist" style="border-bottom: 2px solid #e0eceb;">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="company-info-tab" data-bs-toggle="tab" data-bs-target="#company-info" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-building me-1"></i> بيانات الشركة
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="shareholders-tab" data-bs-toggle="tab" data-bs-target="#shareholders" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-users me-1"></i> المساهمين
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="branches-tab" data-bs-toggle="tab" data-bs-target="#branches" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-code-branch me-1"></i> الفروع
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="meetings-tab" data-bs-toggle="tab" data-bs-target="#meetings" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-calendar-alt me-1"></i> الاجتماعات
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="board-members-tab" data-bs-toggle="tab" data-bs-target="#board-members" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-user-tie me-1"></i> أعضاء المجلس
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="bank-signatures-tab" data-bs-toggle="tab" data-bs-target="#bank-signatures" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-university me-1"></i> صلاحيات التوقيع البنكية
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="non-bank-signatures-tab" data-bs-toggle="tab" data-bs-target="#non-bank-signatures" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
                                <i class="fas fa-file-signature me-1"></i> صلاحيات التوقيع غير البنكية
                            </button>
                        </li>
                    </ul>
                </div>

                <!-- Tabs Content -->
                <div class="tab-content">
                    <!-- Tab 1: Company Info -->
                    <div class="tab-pane fade show active" id="company-info" role="tabpanel">
                        <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
                            <div class="card-header" style="background: linear-gradient(135deg, #f0f9fa, #e8f5f6); color: #4a9f9c; border-bottom: 2px solid #7bc6c3; border-right: 4px solid #7bc6c3;">
                                <span>🏢</span> بيانات الشركة الأساسية
                            </div>
                            <div class="card-body">
                                <form id="companyInfoForm">
                                    <input type="hidden" id="editingCompanyId" />
                                    
                                    <!-- Section 1: المعلومات الأساسية للشركة -->
                                    <div class="sub-section mb-4" style="background: #ffffff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
                                        <h5 class="mb-3" style="color: #4a9f9c; border-right: 4px solid #7bc6c3; padding-right: 12px; margin-bottom: 20px;">
                                            <i class="fas fa-info-circle me-2"></i> المعلومات الأساسية
                                        </h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">اسم الشركة <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="companyName" placeholder="أدخل اسم الشركة" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">العنوان الرئيسي <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="mainAddress" placeholder="أدخل عنوان المقر الرئيسي" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">رقم السجل التجاري <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="commercialRecord" placeholder="أدخل رقم السجل التجاري" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Section 2: بيانات القيد والتسجيل -->
                                    <div class="sub-section mb-4" style="background: #ffffff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
                                        <h5 class="mb-3" style="color: #4a9f9c; border-right: 4px solid #7bc6c3; padding-right: 12px; margin-bottom: 20px;">
                                            <i class="fas fa-registered me-2"></i> بيانات القيد والتسجيل
                                        </h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">تاريخ انتهاء قيد التسجيل <span class="text-danger ms-1">*</span></label>
                                                <input type="date" class="form-control" id="registrationExpiryDate" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">تاريخ التأشير بالسجل التجاري <span class="text-danger ms-1">*</span></label>
                                                <input type="date" class="form-control" id="commercialRecordDate" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">إشعار قبل انتهاء القيد (أيام) <span class="text-danger ms-1">*</span></label>
                                                <input type="number" class="form-control" id="registrationExpiryNotificationDays" placeholder="مثال: 30" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                                <small class="text-muted" style="color: #7bc6c3;">سيتم الإشعار قبل انتهاء القيد</small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Section 3: البيانات الضريبية -->
                                    <div class="sub-section mb-4" style="background: #ffffff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
                                        <h5 class="mb-3" style="color: #4a9f9c; border-right: 4px solid #7bc6c3; padding-right: 12px; margin-bottom: 20px;">
                                            <i class="fas fa-chart-line me-2"></i> البيانات الضريبية
                                        </h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">رقم البطاقة الضريبية <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="taxCard" placeholder="أدخل رقم البطاقة الضريبية" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">تاريخ تجديد البطاقة الضريبية <span class="text-danger ms-1">*</span></label>
                                                <input type="date" class="form-control" id="taxCardRenewalDate" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">إشعار قبل تجديد البطاقة (أيام) <span class="text-danger ms-1">*</span></label>
                                                <input type="number" class="form-control" id="taxCardNotificationDays" placeholder="مثال: 30" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                                <small class="text-muted" style="color: #7bc6c3;">سيتم الإشعار قبل تاريخ التجديد</small>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">ضريبة القيمة المضافة <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="vatNumber" placeholder="أدخل رقم ضريبة القيمة المضافة" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Section 4: مراقب الحسابات -->
                                    <div class="sub-section mb-4" style="background: #ffffff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
                                        <h5 class="mb-3" style="color: #4a9f9c; border-right: 4px solid #7bc6c3; padding-right: 12px; margin-bottom: 20px;">
                                            <i class="fas fa-user-check me-2"></i> مراقب الحسابات
                                        </h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">اسم مراقب الحسابات <span class="text-danger ms-1">*</span></label>
                                                <input type="text" class="form-control" id="auditor" placeholder="اسم مراقب الحسابات" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">تاريخ تعيين مراقب الحسابات <span class="text-danger ms-1">*</span></label>
                                                <input type="date" class="form-control" id="auditorAppointmentDate" style="border-radius: 10px; border: 1px solid #e0eceb;">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Section 5: رأس المال -->
                                    <div class="sub-section mb-4" style="background: #ffffff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
                                        <h5 class="mb-3" style="color: #4a9f9c; border-right: 4px solid #7bc6c3; padding-right: 12px; margin-bottom: 20px;">
                                            <i class="fas fa-money-bill-wave me-2"></i> رأس المال
                                        </h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">رأس المال المرخص به (جنيه) <span class="text-danger ms-1">*</span></label>
                                                <div class="d-flex gap-2">
                                                    <input type="number" class="form-control" id="authorizedCapital" placeholder="رأس المال" step="0.01" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 2;">
                                                    <input type="date" class="form-control" id="authorizedCapitalRecordDate" placeholder="تاريخ التأشير" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 1.5;">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">رأس المال المصدر (جنيه) <span class="text-danger ms-1">*</span></label>
                                                <div class="d-flex gap-2">
                                                    <input type="number" class="form-control" id="issuedCapital" placeholder="رأس المال" step="0.01" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 2;">
                                                    <input type="date" class="form-control" id="issuedCapitalRecordDate" placeholder="تاريخ التأشير" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 1.5;">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold" style="color: #4a9f9c;">رأس المال المدفوع (جنيه) <span class="text-danger ms-1">*</span></label>
                                                <div class="d-flex gap-2">
                                                    <input type="number" class="form-control" id="paidCapital" placeholder="رأس المال" step="0.01" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 2;">
                                                    <input type="date" class="form-control" id="paidCapitalRecordDate" placeholder="تاريخ التأشير" style="border-radius: 10px; border: 1px solid #e0eceb; flex: 1.5;">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Tab 2: Shareholders -->
                    <div class="tab-pane fade" id="shareholders" role="tabpanel">
                        <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
